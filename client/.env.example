# Public URL of the CRAZY RACING Socket.IO/HTTP server.
# This value is embedded in the client bundle and is not a secret.
VITE_SERVER_URL=http://localhost:3001

# Public Supabase browser credentials.
# Obtain these from Supabase -> Project Settings -> API.
# The project URL and anon/publishable key are safe to expose in the browser
# when Row Level Security and server-side authorization are configured correctly.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
