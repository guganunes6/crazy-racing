# Runtime mode: development, test, or production.
NODE_ENV=development

# Render supplies PORT automatically in production.
PORT=3001

# Use CLIENT_URL for one frontend, or CLIENT_URLS for a comma-separated list.
CLIENT_URL=http://localhost:5173
# CLIENT_URLS=http://localhost:5173,http://localhost:4173,https://your-project.pages.dev

# Optional release and logging metadata.
APP_VERSION=0.6.0
LOG_LEVEL=debug

# Supabase project credentials.
# SUPABASE_ANON_KEY is public-capability configuration.
# SUPABASE_SERVICE_ROLE_KEY is secret and must never be exposed to the client.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# PostgreSQL connections copied from Supabase -> Connect.
# For a persistent Render server, the Supavisor Session pooler (port 5432)
# is a suitable free-plan default for DATABASE_URL.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_SESSION_POOLER_HOST:5432/postgres?sslmode=require

# Prisma CLI/migrations connection. You may use the same Session pooler URL.
# A direct connection is also valid when your network supports it.
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_SESSION_POOLER_HOST:5432/postgres?sslmode=require
