# Runtime mode: development, test, or production
NODE_ENV=development

# Render supplies PORT automatically in production.
PORT=3001

# Use CLIENT_URL for one frontend, or CLIENT_URLS for a comma-separated list.
CLIENT_URL=http://localhost:5173
# CLIENT_URLS=http://localhost:5173,https://your-project.pages.dev

# Optional release and logging metadata.
APP_VERSION=0.5.0
LOG_LEVEL=debug
